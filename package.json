{
	"name": "anytrend",
	"version": "0.2.1",
	"description": "AI-driven daily trend aggregation command library for Chinese and English hot rankings.",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"bin": {
		"anytrend": "dist/cli.js"
	},
	"exports": {
		".": {
			"types": "dist/index.d.ts",
			"import": "dist/index.js"
		}
	},
	"files": [
		"dist",
		"config",
		"assets",
		"README.md",
		"LICENSE"
	],
	"packageManager": "npm@11.15.0",
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"clean": "node --input-type=module -e \"import fs from 'node:fs'; fs.rmSync('dist', {recursive:true, force:true})\"",
		"build": "npm run clean && tsc && node scripts/copy-site-templates.js",
		"typecheck": "tsc --noEmit",
		"check": "biome check --error-on-warnings .",
		"check:fix": "biome check --write --error-on-warnings .",
		"format": "biome format --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:unit": "vitest run --project unit",
		"test:integration": "vitest run --project integration",
		"test:e2e": "vitest run --project e2e",
		"test:e2e:live": "node --input-type=module -e \"process.env.RUN_E2E_LIVE='1'; import { spawn } from 'node:child_process'; spawn('npx', ['vitest','run','--project','e2e'], {stdio:'inherit', env:process.env, shell:true})\"",
		"normalize": "tsx src/cli.ts normalize",
		"normalize:batch": "tsx src/cli.ts normalize-batch",
		"collect:daily": "tsx src/cli.ts build",
		"merge:daily": "tsx src/cli.ts merge",
		"aggregate:daily": "tsx src/cli.ts daily-site aggregate",
		"render:daily": "tsx src/cli.ts daily-site render",
		"prepublishOnly": "npm run build && npm run check && npm run typecheck && npm run test"
	},
	"keywords": [
		"trend",
		"websculpt",
		"daily",
		"hot",
		"aggregator",
		"ai-workflow"
	],
	"author": "bqw",
	"license": "MIT",
	"dependencies": {
		"commander": "^15.0.0",
		"ejs": "^3.1.10",
		"he": "^1.2.0",
		"js-yaml": "^5.2.0",
		"picocolors": "^1.1.1",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.5",
		"@types/ejs": "^3.1.5",
		"@types/he": "^1.2.3",
		"@types/node": "^25.9.3",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3",
		"vitest": "^4.1.9"
	}
}
